<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= weather ? weather.city + ' — Weather' : 'Weather App' %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;1,300&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="<%= weather ? 'bg-' + weather.bg : 'bg-default' %>">

  <div class="noise"></div>

  <div class="container">

    <!-- ── Header / Search ── -->
    <header>
      <div class="logo">
        <span class="logo-icon">◈</span>
        <span class="logo-text">Skyline</span>
      </div>

      <form class="search-form" action="/weather" method="POST">
        <input
          type="text"
          name="city"
          class="search-input"
          placeholder="Search city…"
          value="<%= query %>"
          autocomplete="off"
          autofocus
        />
        <button type="submit" class="search-btn" aria-label="Search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
      </form>
    </header>

    <!-- ── Error ── -->
    <% if (error) { %>
    <div class="error-card">
      <span class="error-icon">⚠</span>
      <p><%= error %></p>
    </div>
    <% } %>

    <!-- ── No result yet ── -->
    <% if (!weather && !error) { %>
    <div class="hero-prompt">
      <div class="hero-icon">🌍</div>
      <h1>Your weather,<br/><em>anywhere on Earth.</em></h1>
      <p>Type a city name above to get started.</p>
    </div>
    <% } %>

    <!-- ── Weather Result ── -->
    <% if (weather) { %>
    <main class="weather-grid">

      <!-- Current -->
      <section class="card card-main">
        <div class="card-location">
          <span class="pin-icon">📍</span>
          <%= weather.city %>, <%= weather.country %>
        </div>
        <div class="card-temp"><%= weather.temp %>°</div>
        <div class="card-desc"><%= weather.description %></div>
        <div class="card-feels">Feels like <strong><%= weather.feels_like %>°C</strong></div>
        <img
          class="card-icon"
          src="https://openweathermap.org/img/wn/<%= weather.icon %>@4x.png"
          alt="<%= weather.description %>"
        />
      </section>

      <!-- Stats -->
      <section class="card card-stats">
        <h2 class="card-title">Details</h2>
        <ul class="stats-list">
          <li>
            <span class="stat-label">💧 Humidity</span>
            <span class="stat-value"><%= weather.humidity %>%</span>
          </li>
          <li>
            <span class="stat-label">💨 Wind</span>
            <span class="stat-value"><%= weather.wind_speed %> km/h <em><%= weather.wind_dir %></em></span>
          </li>
          <li>
            <span class="stat-label">🌡 Pressure</span>
            <span class="stat-value"><%= weather.pressure %> hPa</span>
          </li>
          <li>
            <span class="stat-label">👁 Visibility</span>
            <span class="stat-value"><%= weather.visibility %> km</span>
          </li>
          <li>
            <span class="stat-label">🌅 Sunrise</span>
            <span class="stat-value"><%= weather.sunrise %></span>
          </li>
          <li>
            <span class="stat-label">🌇 Sunset</span>
            <span class="stat-value"><%= weather.sunset %></span>
          </li>
        </ul>
      </section>

      <!-- 5-Day Forecast -->
      <section class="card card-forecast">
        <h2 class="card-title">5-Day Forecast</h2>
        <div class="forecast-row">
          <% weather.forecast.forEach(day => { %>
          <div class="forecast-day">
            <span class="forecast-name"><%= day.day %></span>
            <img
              src="https://openweathermap.org/img/wn/<%= day.icon %>@2x.png"
              alt="<%= day.desc %>"
            />
            <span class="forecast-desc"><%= day.desc %></span>
            <div class="forecast-temps">
              <span class="hi"><%= day.high %>°</span>
              <span class="sep">/</span>
              <span class="lo"><%= day.low %>°</span>
            </div>
          </div>
          <% }); %>
        </div>
      </section>

    </main>
    <% } %>

  </div><!-- /container -->

  <footer>
    <p>Data by <a href="https://openweathermap.org" target="_blank" rel="noopener">OpenWeatherMap - Thapa Technical</a></p>
  </footer>

</body>
</html>
